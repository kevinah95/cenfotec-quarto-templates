{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    "assigment": {
      "component": "assigment",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "_extensions/assigment/_extension.yml",
          "jsonpath": "$.version"
        }
      ]
    },
    "slides-basic": {
      "component": "slides-basic",
      "release-type": "simple",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "yaml",
          "path": "_extensions/slides-basic/_extension.yml",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
